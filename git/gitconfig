[user]
	# REMPLACE avec tes informations
	name = GuillemotClement
	email = guillemot.clement@protonmail.com 

[core]
	editor = vim
	autocrlf = input
	# Ignore les changements de permissions
	filemode = false

[init]
	defaultBranch = main

[color]
	ui = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold

[color "status"]
	added = green
	changed = yellow
	untracked = red

[alias]
	# Raccourcis utiles
	st = status
	co = checkout
	br = branch
	ci = commit
	unstage = reset HEAD --
	last = log -1 HEAD
	visual = log --graph --oneline --decorate --all
	
	# Affichage amélioré du log
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

[push]
	default = simple
	followTags = true

[pull]
	rebase = false

[fetch]
	prune = true

[diff]
	tool = vimdiff

[merge]
	tool = vimdiff
	conflictstyle = diff3

[credential]
	helper = cache --timeout=3600